{
  "name": "blackroad-os",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "doctor": "node src/blackroad/doctor/blackroadDoctor.js",
    "doctor:report": "node src/blackroad/doctor/blackroadDoctor.js --write-report",
    "launch:check": "node src/blackroad/doctor/runLaunchChecks.js",
    "launch:queue": "node src/blackroad/launch/launchQueue.js",
    "patch:preview": "node src/blackroad/patch/safePatchExecutor.js --preview",
    "patch:safe": "node src/blackroad/patch/safePatchExecutor.js --apply-safe",
    "patch:verify": "node src/blackroad/patch/patchVerifier.js",
    "patch:rollback": "node src/blackroad/patch/patchRollback.js",
    "release:plan": "node src/blackroad/release/releasePlan.js",
    "release:gates": "node src/blackroad/release/releaseGates.js",
    "release:build": "node src/blackroad/release/buildAll.js",
    "release:preview": "node src/blackroad/release/previewChecks.js",
    "release:report": "node src/blackroad/release/releaseReport.js",
    "preview:server": "node src/blackroad/release/previewServer.js",
    "check:command-dock": "node src/blackroad/compliance/checkCommandDock.js",
    "report:command-dock": "node src/blackroad/compliance/checkCommandDock.js --write-report"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}

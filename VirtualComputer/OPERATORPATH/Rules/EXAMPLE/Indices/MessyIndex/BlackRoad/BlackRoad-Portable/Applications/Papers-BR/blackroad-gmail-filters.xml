<?xml version='1.0' encoding='UTF-8'?>
<feed xmlns='http://www.w3.org/2005/Atom' xmlns:apps='http://schemas.google.com/apps/2006'>
    <title>BlackRoad OS Mail Filters</title>

    <!-- 🚨 URGENT — payments, legal, DMCA, invoices -->
    <entry>
        <category term='filter'></category>
        <title>BlackRoad Urgent</title>
        <apps:property name='to' value='amundsonalexa+urgent@gmail.com'/>
        <apps:property name='label' value='🚨 Urgent'/>
        <apps:property name='shouldNeverSpam' value='true'/>
        <apps:property name='shouldStar' value='true'/>
    </entry>

    <!-- 📬 SUPPORT — hello@, support@, contact@, hi@, help@ -->
    <entry>
        <category term='filter'></category>
        <title>BlackRoad Support</title>
        <apps:property name='to' value='amundsonalexa+support@gmail.com'/>
        <apps:property name='label' value='📬 Support'/>
        <apps:property name='shouldNeverSpam' value='true'/>
    </entry>

    <!-- 📧 GENERAL MAIL — everything else from your 20 domains -->
    <entry>
        <category term='filter'></category>
        <title>BlackRoad Mail</title>
        <apps:property name='to' value='amundsonalexa+mail@gmail.com'/>
        <apps:property name='label' value='📧 BlackRoad Mail'/>
        <apps:property name='shouldNeverSpam' value='true'/>
        <apps:property name='shouldArchive' value='true'/>
    </entry>

</feed>

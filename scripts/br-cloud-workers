COLORS = {
    "product": "\033[1;37m", "agent": "\033[0;33m", "ai": "\033[0;33m",
    "auth": "\033[0;31m", "analytics": "\033[0;35m", "billing": "\033[0;32m",
    "fleet": "\033[0;36m", "integration": "\033[0;36m", "monitor": "\033[0;36m",
    "pipeline": "\033[0;32m", "notify": "\033[0;32m", "domain": "\033[0;90m",
    "user": "\033[0;35m", "blockchain": "\033[0;33m", "lucidia": "\033[1;37m",
}
N = "\033[0m"
W = "\033[1;37m"
D = "\033[0;90m"

mode = sys.argv[1] if len(sys.argv) > 1 else "summary"

total = 0
for div, items in sorted(DIVISIONS.items()):
    c = COLORS.get(div, D)
    count = len(items)
    total += count

    if mode == "full":
        print(f"  {c}[{div}]{N} ({count} workers)")
        for item in items:
            parts = item.split(":", 1)
            name = parts[0]
            endpoint = parts[1] if len(parts) > 1 and parts[1] else f"{name}.blackroad.workers.dev"
            print(f"    {c}*{N} {name:40s} {D}{endpoint}{N}")
        print()
    else:
        print(f"  {c}{div:15s}{N} {W}{count:3d}{N} workers")

print()
print(f"  {D}────────────────────────────────────────────────{N}")
print(f"  {W}{total} cloud workers{N} across {W}{len(DIVISIONS)} divisions{N}")

# Additional stats
print(f"  {D}+ ~300 infrastructure/utility workers not listed{N}")
print(f"  {D}+ 53 D1 databases | 20 domains | 27 agents{N}")
PYEOF

printf "\n  ${D}Pave Tomorrow.${N}\n\n"

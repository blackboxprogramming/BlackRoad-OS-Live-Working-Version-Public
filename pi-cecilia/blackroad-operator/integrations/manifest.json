      "auth_type": "bearer_token",
      "env_vars": ["NOTION_API_KEY", "NOTION_DATABASE_ID"],
      "capabilities": ["pages", "databases", "blocks", "search", "comments"]
    },
    {
      "id": "linear",
      "name": "Linear",
      "category": "project-management",
      "status": "active",
      "description": "Issue tracking — issues, projects, cycles, teams",
      "api_base": "https://api.linear.app/graphql",
      "auth_type": "bearer_token",
      "env_vars": ["LINEAR_API_KEY"],
      "capabilities": ["issues", "projects", "cycles", "teams", "labels", "webhooks"]
    },
    {
      "id": "cloudflare",
      "name": "Cloudflare",
      "category": "cloud-deploy",
      "status": "active",
      "description": "Edge platform — workers, pages, DNS, R2, KV, D1, tunnels",
      "api_base": "https://api.cloudflare.com/client/v4",
      "auth_type": "bearer_token",
      "env_vars": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"],
      "capabilities": ["workers", "pages", "dns", "r2", "kv", "d1", "tunnels", "zones"]
    },
    {

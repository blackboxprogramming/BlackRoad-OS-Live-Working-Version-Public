{
  "name": "blackroad-integrations",
  "version": "1.0.0",
  "description": "BlackRoad OS — Unified Integration Layer for all external services",
  "owner": "BlackRoad OS, Inc.",
  "created": "2026-02-28",
  "categories": {
    "banking": ["mercury"],
    "payments": ["stripe", "stripe-atlas"],
    "ai-providers": ["claude", "chatgpt", "gemini", "grok", "xai", "huggingface"],
    "cloud-deploy": ["cloudflare", "railway", "vercel", "digitalocean"],
    "project-management": ["notion", "linear", "jira"],
    "crm": ["salesforce"],
    "communication": ["slack", "email", "instagram"],
    "auth": ["clerk", "enclave"],
    "infrastructure": ["tailscale", "raspberry-pi", "termius"],
    "mobile-tools": ["pyto", "shellfish", "working-copy", "ish"],
    "storage": ["google-drive"]
  },
  "integrations": [
    {
      "id": "mercury",
      "name": "Mercury",
      "category": "banking",
      "status": "active",
      "description": "Business banking — accounts, transactions, payments",
      "api_base": "https://api.mercury.com/api/v1",
      "auth_type": "bearer_token",
      "env_vars": ["MERCURY_API_TOKEN"],
      "capabilities": ["accounts", "transactions", "payments", "recipients"]
    },
    {
      "id": "stripe",
      "name": "Stripe",
      "category": "payments",
      "status": "active",
      "description": "Payment processing — charges, subscriptions, invoices",
      "api_base": "https://api.stripe.com/v1",
      "auth_type": "bearer_token",
      "env_vars": ["STRIPE_SECRET_KEY", "STRIPE_PUBLISHABLE_KEY", "STRIPE_WEBHOOK_SECRET"],
      "capabilities": ["charges", "subscriptions", "invoices", "customers", "products", "webhooks"]
    },
    {
      "id": "stripe-atlas",
      "name": "Stripe Atlas",
      "category": "payments",
      "status": "active",
      "description": "Company formation and management via Stripe Atlas",
      "api_base": "https://api.stripe.com/v1",
      "auth_type": "bearer_token",
      "env_vars": ["STRIPE_SECRET_KEY"],
      "capabilities": ["company-status", "formation-docs", "banking-setup"]
    },
    {
      "id": "huggingface",
      "name": "Hugging Face",
      "category": "ai-providers",
      "status": "active",
      "description": "Model hub — inference, model management, spaces",
      "api_base": "https://huggingface.co/api",
      "auth_type": "bearer_token",
      "env_vars": ["HUGGINGFACE_TOKEN"],
      "capabilities": ["inference", "models", "datasets", "spaces", "repos"]
    },
    {
      "id": "google-drive",
      "name": "Google Drive",
      "category": "storage",
      "status": "active",
      "description": "Cloud storage — files, folders, sharing, sync",
      "api_base": "https://www.googleapis.com/drive/v3",
      "auth_type": "oauth2",
      "env_vars": ["GOOGLE_CLIENT_ID", "GOOGLE_CLIENT_SECRET", "GOOGLE_REFRESH_TOKEN"],
      "capabilities": ["files", "folders", "sharing", "search", "export"]
    },
    {
      "id": "notion",
      "name": "Notion",
      "category": "project-management",
      "status": "active",
      "description": "Workspace — pages, databases, blocks, search",

stream_events() {
    zsh "${BR_TOOLS_DIR}/agent-gateway/br-gateway.sh" stream
}

dispatch_tool() {
    local tool=$1
    shift
    local script="${BR_TOOLS[$tool]}"
    if [[ -n "$script" && -f "$script" ]]; then
        "$script" "$@"
        return 0
    fi
    return 1
}


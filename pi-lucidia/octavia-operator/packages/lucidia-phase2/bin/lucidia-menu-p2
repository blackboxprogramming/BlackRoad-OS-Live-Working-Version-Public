#!/usr/bin/env bash

AGENTS=(
  "lucidia"
  "alice"
  "octavia"
  "enclave"
)

echo ""
echo "🧠 Lucidia Operator Menu — Phase 2"
echo "---------------------------------"

select AGENT in "${AGENTS[@]}"; do
  if [[ -n "$AGENT" ]]; then
    echo ""
    echo "▶ Launching $AGENT (Phase 2 context)"
    echo ""
    ollama run "$AGENT"
    break
  else
    echo "Invalid selection."
  fi
done

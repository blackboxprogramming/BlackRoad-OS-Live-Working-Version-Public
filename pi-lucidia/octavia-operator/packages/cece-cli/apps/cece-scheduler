#!/bin/bash
# ⏰ CECE-SCHEDULER v1.0 - Task Scheduling System
# Cron-like scheduling with persistent jobs

PINK='\033[38;5;205m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
WHITE='\033[1;37m'
NC='\033[0m'

CECE_HOME="${CECE_HOME:-$HOME/cece}"
SCHEDULER_DIR="$CECE_HOME/scheduler"
JOBS_FILE="$SCHEDULER_DIR/jobs.jsonl"
LOG_FILE="$SCHEDULER_DIR/scheduler.log"
PID_FILE="$SCHEDULER_DIR/scheduler.pid"

mkdir -p "$SCHEDULER_DIR"

banner() {
    echo -e "${PINK}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${PINK}║${NC}            ${WHITE}⏰ CECE-SCHEDULER - Task Scheduling${NC}             ${PINK}║${NC}"
    echo -e "${PINK}╚════════════════════════════════════════════════════════════╝${NC}"
}

log_event() {
    echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $1" >> "$LOG_FILE"
}

generate_id() {
    date +%s%N | sha256sum | head -c 8
}

# Add a scheduled job
cmd_add() {
    local schedule="$1"
    local command="$2"
    local name="${3:-job-$(generate_id)}"

    if [ -z "$schedule" ] || [ -z "$command" ]; then
        echo -e "${RED}Error:${NC} Missing arguments"
        echo "Usage: cece-scheduler add <schedule> <command> [name]"
        echo ""
        echo "Schedule formats:"
        echo "  @hourly    - Every hour"
        echo "  @daily     - Every day at midnight"
        echo "  @weekly    - Every Sunday"
        echo "  @reboot    - On system startup"
        echo "  */5        - Every 5 minutes"
        echo "  0 9 * * *  - Cron format (9 AM daily)"
        return 1
    fi

    local id=$(generate_id)
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local job=$(cat << EOF
{"id":"$id","name":"$name","schedule":"$schedule","command":"$command","enabled":true,"created":"$timestamp","last_run":null,"run_count":0}
EOF
)

    echo "$job" >> "$JOBS_FILE"
    echo -e "${GREEN}✓${NC} Job added: ${CYAN}$name${NC} (ID: $id)"
    echo "  Schedule: $schedule"
    echo "  Command: $command"

    log_event "ADDED: $id - $name"
}

# List all jobs
cmd_list() {
    banner
    echo ""

    if [ ! -f "$JOBS_FILE" ] || [ ! -s "$JOBS_FILE" ]; then
        echo "No scheduled jobs. Use 'cece-scheduler add' to create one."
        return
    fi

    echo -e "${WHITE}Scheduled Jobs:${NC}"
    echo ""
    printf "  ${CYAN}%-10s %-15s %-12s %-8s %s${NC}\n" "ID" "NAME" "SCHEDULE" "RUNS" "COMMAND"
    echo "  ────────────────────────────────────────────────────────────────"

    while read -r line; do
        local id=$(echo "$line" | jq -r '.id')
        local name=$(echo "$line" | jq -r '.name')
        local schedule=$(echo "$line" | jq -r '.schedule')
        local command=$(echo "$line" | jq -r '.command' | cut -c1-30)
        local enabled=$(echo "$line" | jq -r '.enabled')
        local run_count=$(echo "$line" | jq -r '.run_count')

        local status=""
        if [ "$enabled" = "true" ]; then
            status="${GREEN}●${NC}"
        else
            status="${RED}○${NC}"
        fi

        printf "  $status %-10s %-15s %-12s %-8s %s\n" "$id" "$name" "$schedule" "$run_count" "$command"
    done < "$JOBS_FILE"

    echo ""
    local total=$(wc -l < "$JOBS_FILE")
    echo -e "  ${WHITE}Total: $total jobs${NC}"
}

# Remove a job
cmd_remove() {
    local id="$1"

    if [ -z "$id" ]; then
        echo -e "${RED}Error:${NC} Please specify job ID"
        return 1
    fi

    local tmp=$(mktemp)
    grep -v "\"id\":\"$id\"" "$JOBS_FILE" > "$tmp" 2>/dev/null
    mv "$tmp" "$JOBS_FILE"

    echo -e "${GREEN}✓${NC} Job ${CYAN}$id${NC} removed"
    log_event "REMOVED: $id"
}

# Enable/disable a job
cmd_toggle() {
    local id="$1"
    local action="${2:-toggle}"

    if [ -z "$id" ]; then
        echo -e "${RED}Error:${NC} Please specify job ID"
        return 1
    fi

    local tmp=$(mktemp)
    while read -r line; do
        if echo "$line" | grep -q "\"id\":\"$id\""; then
            local current=$(echo "$line" | jq -r '.enabled')
            if [ "$action" = "enable" ]; then
                echo "$line" | jq -c '.enabled = true'
            elif [ "$action" = "disable" ]; then
                echo "$line" | jq -c '.enabled = false'
            else
                # Toggle
                if [ "$current" = "true" ]; then
                    echo "$line" | jq -c '.enabled = false'
                else
                    echo "$line" | jq -c '.enabled = true'
                fi
            fi
        else
            echo "$line"
        fi
    done < "$JOBS_FILE" > "$tmp"
    mv "$tmp" "$JOBS_FILE"

    echo -e "${GREEN}✓${NC} Job ${CYAN}$id${NC} toggled"
}

# Run a job manually
cmd_run() {
    local id="$1"

    if [ -z "$id" ]; then
        echo -e "${RED}Error:${NC} Please specify job ID"
        return 1
    fi

    local job=$(grep "\"id\":\"$id\"" "$JOBS_FILE")
    if [ -z "$job" ]; then
        echo -e "${RED}Error:${NC} Job not found"
        return 1
    fi

    local name=$(echo "$job" | jq -r '.name')
    local command=$(echo "$job" | jq -r '.command')

    echo -e "${CYAN}Running job: $name${NC}"
    echo "  Command: $command"
    echo ""

    # Execute the command
    eval "$command"
    local exit_code=$?

    # Update run count and last_run
    local tmp=$(mktemp)
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    while read -r line; do
        if echo "$line" | grep -q "\"id\":\"$id\""; then
            echo "$line" | jq -c ".last_run = \"$timestamp\" | .run_count += 1"
        else
            echo "$line"
        fi
    done < "$JOBS_FILE" > "$tmp"
    mv "$tmp" "$JOBS_FILE"

    echo ""
    if [ $exit_code -eq 0 ]; then
        echo -e "${GREEN}✓${NC} Job completed successfully"
    else
        echo -e "${RED}✗${NC} Job failed with exit code $exit_code"
    fi

    log_event "RUN: $id - $name (exit: $exit_code)"
}

# Parse schedule and check if should run now
should_run_now() {
    local schedule="$1"
    local minute=$(date +%M)
    local hour=$(date +%H)
    local day=$(date +%d)
    local month=$(date +%m)
    local weekday=$(date +%u)

    case "$schedule" in
        "@hourly")
            [ "$minute" = "00" ] && return 0
            ;;
        "@daily")
            [ "$hour" = "00" ] && [ "$minute" = "00" ] && return 0
            ;;
        "@weekly")
            [ "$weekday" = "7" ] && [ "$hour" = "00" ] && [ "$minute" = "00" ] && return 0
            ;;
        "*/1")
            return 0  # Every minute
            ;;
        "*/5")
            [ $((10#$minute % 5)) -eq 0 ] && return 0
            ;;
        "*/10")
            [ $((10#$minute % 10)) -eq 0 ] && return 0
            ;;
        "*/15")
            [ $((10#$minute % 15)) -eq 0 ] && return 0
            ;;
        "*/30")
            [ $((10#$minute % 30)) -eq 0 ] && return 0
            ;;
        *)
            # Try to parse as cron format (minute hour day month weekday)
            local cron_min=$(echo "$schedule" | awk '{print $1}')
            local cron_hour=$(echo "$schedule" | awk '{print $2}')

            if [ "$cron_min" = "*" ] || [ "$cron_min" = "$minute" ]; then
                if [ "$cron_hour" = "*" ] || [ "$cron_hour" = "$hour" ]; then
                    return 0
                fi
            fi
            ;;
    esac

    return 1
}

# Daemon mode - run scheduled jobs
cmd_daemon() {
    echo -e "${CYAN}Starting scheduler daemon...${NC}"
    echo $$ > "$PID_FILE"

    log_event "DAEMON: Started (PID: $$)"

    while true; do
        if [ -f "$JOBS_FILE" ]; then
            while read -r job; do
                local id=$(echo "$job" | jq -r '.id')
                local enabled=$(echo "$job" | jq -r '.enabled')
                local schedule=$(echo "$job" | jq -r '.schedule')
                local command=$(echo "$job" | jq -r '.command')
                local name=$(echo "$job" | jq -r '.name')

                if [ "$enabled" = "true" ] && should_run_now "$schedule"; then
                    log_event "TRIGGER: $id - $name"
                    eval "$command" >> "$LOG_FILE" 2>&1 &

                    # Update stats
                    local tmp=$(mktemp)
                    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
                    while read -r line; do
                        if echo "$line" | grep -q "\"id\":\"$id\""; then
                            echo "$line" | jq -c ".last_run = \"$timestamp\" | .run_count += 1"
                        else
                            echo "$line"
                        fi
                    done < "$JOBS_FILE" > "$tmp"
                    mv "$tmp" "$JOBS_FILE"
                fi
            done < "$JOBS_FILE"
        fi

        sleep 60  # Check every minute
    done
}

# Show logs
cmd_logs() {
    local lines="${1:-50}"
    echo -e "${CYAN}📜 Scheduler Logs (last $lines):${NC}"
    echo ""
    tail -n "$lines" "$LOG_FILE" 2>/dev/null || echo "No logs yet"
}

# Help
cmd_help() {
    banner
    echo ""
    echo -e "${WHITE}Usage:${NC} cece-scheduler <command> [args]"
    echo ""
    echo -e "${CYAN}Commands:${NC}"
    echo "  add <schedule> <cmd> [name]  Add a scheduled job"
    echo "  list                         List all jobs"
    echo "  remove <id>                  Remove a job"
    echo "  enable <id>                  Enable a job"
    echo "  disable <id>                 Disable a job"
    echo "  run <id>                     Run job manually"
    echo "  daemon                       Start scheduler daemon"
    echo "  logs [n]                     Show last n log lines"
    echo ""
    echo -e "${WHITE}Schedule Formats:${NC}"
    echo "  @hourly        Every hour at :00"
    echo "  @daily         Every day at midnight"
    echo "  @weekly        Every Sunday at midnight"
    echo "  */5            Every 5 minutes"
    echo "  */15           Every 15 minutes"
    echo "  0 9 * * *      Cron format (9 AM daily)"
    echo ""
    echo -e "${WHITE}Examples:${NC}"
    echo "  cece-scheduler add @hourly 'cece-backup create' backup"
    echo "  cece-scheduler add '*/5' 'cece-sync push' sync-job"
    echo "  cece-scheduler add '0 6 * * *' 'cece-metrics collect' morning-metrics"
}

# Main
main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        add) cmd_add "$@" ;;
        list|ls) cmd_list ;;
        remove|rm|delete) cmd_remove "$@" ;;
        enable) cmd_toggle "$1" enable ;;
        disable) cmd_toggle "$1" disable ;;
        toggle) cmd_toggle "$@" ;;
        run) cmd_run "$@" ;;
        daemon|start) cmd_daemon ;;
        logs) cmd_logs "$@" ;;
        help|--help|-h) cmd_help ;;
        *) echo "Unknown command: $cmd"; cmd_help ;;
    esac
}

main "$@"

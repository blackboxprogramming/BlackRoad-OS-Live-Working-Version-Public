#!/bin/bash
# 🤖 CECE-AI-CHAT v1.0 - Conversational AI with History
# Persistent chat with Ollama, remembers context

PINK='\033[38;5;205m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
WHITE='\033[1;37m'
NC='\033[0m'

CECE_HOME="${CECE_HOME:-$HOME/cece}"
CHAT_DIR="$CECE_HOME/ai/chats"
CHAT_HISTORY="$CHAT_DIR/current.jsonl"
MODEL="${CECE_MODEL:-llama3.2}"

mkdir -p "$CHAT_DIR"

banner() {
    echo -e "${PINK}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${PINK}║${NC}             ${WHITE}🤖 CECE AI Chat - Powered by Ollama${NC}          ${PINK}║${NC}"
    echo -e "${PINK}╚════════════════════════════════════════════════════════════╝${NC}"
    echo -e "  Model: ${CYAN}$MODEL${NC} | Type ${YELLOW}/help${NC} for commands"
    echo ""
}

# Save message to history
save_message() {
    local role="$1"
    local content="$2"
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    echo "{\"time\":\"$timestamp\",\"role\":\"$role\",\"content\":$(echo "$content" | jq -Rs .)}" >> "$CHAT_HISTORY"
}

# Get conversation context (last N messages)
get_context() {
    local n="${1:-10}"
    if [ -f "$CHAT_HISTORY" ]; then
        tail -n "$n" "$CHAT_HISTORY" | jq -r '"<" + .role + ">: " + .content' 2>/dev/null
    fi
}

# Build prompt with context
build_prompt() {
    local user_msg="$1"
    local context=$(get_context 6)

    cat << EOF
You are CECE, a helpful AI assistant running on a Raspberry Pi. You have a warm, friendly personality.
You remember our conversation. Here's our recent chat:

$context

<user>: $user_msg

Respond naturally and helpfully. Keep responses concise but complete.
EOF
}

# Chat with Ollama
chat() {
    local prompt="$1"

    # Save user message
    save_message "user" "$prompt"

    # Build full prompt with context
    local full_prompt=$(build_prompt "$prompt")

    # Get response from Ollama
    echo -e "${CYAN}CECE:${NC} "
    local response=$(ollama run "$MODEL" "$full_prompt" 2>/dev/null)

    if [ -n "$response" ]; then
        echo "$response"
        save_message "assistant" "$response"
    else
        echo -e "${RED}Error: Could not get response from Ollama${NC}"
    fi
    echo ""
}

# Show chat history
show_history() {
    echo -e "${CYAN}📜 Chat History:${NC}"
    echo ""
    if [ -f "$CHAT_HISTORY" ]; then
        cat "$CHAT_HISTORY" | jq -r '
            "\(.time | split("T")[1] | split(".")[0]) " +
            (if .role == "user" then "👤 You: " else "🤖 CECE: " end) +
            .content' 2>/dev/null | tail -20
    else
        echo "  No chat history yet"
    fi
    echo ""
}

# Clear chat history
clear_history() {
    local backup="$CHAT_DIR/chat-$(date +%Y%m%d-%H%M%S).jsonl"
    if [ -f "$CHAT_HISTORY" ]; then
        mv "$CHAT_HISTORY" "$backup"
        echo -e "${GREEN}✓${NC} Chat cleared (backed up to $backup)"
    else
        echo "No chat history to clear"
    fi
}

# List available models
list_models() {
    echo -e "${CYAN}📦 Available Models:${NC}"
    echo ""
    ollama list 2>/dev/null | while read line; do
        echo "  $line"
    done
    echo ""
    echo -e "Current: ${GREEN}$MODEL${NC}"
    echo "Change with: export CECE_MODEL=<model>"
}

# Export conversation
export_chat() {
    local outfile="${1:-$CHAT_DIR/export-$(date +%Y%m%d).md}"

    echo "# CECE Chat Export" > "$outfile"
    echo "Date: $(date)" >> "$outfile"
    echo "" >> "$outfile"

    if [ -f "$CHAT_HISTORY" ]; then
        cat "$CHAT_HISTORY" | jq -r '
            "**" + (if .role == "user" then "You" else "CECE" end) + "** (" + .time + "):\n" + .content + "\n"
        ' >> "$outfile"
    fi

    echo -e "${GREEN}✓${NC} Exported to $outfile"
}

# Show help
show_help() {
    echo -e "${CYAN}Commands:${NC}"
    echo "  /help      Show this help"
    echo "  /history   Show chat history"
    echo "  /clear     Clear chat history"
    echo "  /models    List available models"
    echo "  /export    Export chat to markdown"
    echo "  /quit      Exit chat"
    echo ""
}

# Interactive chat loop
interactive() {
    banner

    while true; do
        echo -ne "${GREEN}You:${NC} "
        read -r input

        # Handle empty input
        [ -z "$input" ] && continue

        # Handle commands
        case "$input" in
            /help)
                show_help
                ;;
            /history)
                show_history
                ;;
            /clear)
                clear_history
                ;;
            /models)
                list_models
                ;;
            /export*)
                export_chat ${input#/export }
                ;;
            /quit|/exit|/q)
                echo -e "${PINK}Goodbye! 💜${NC}"
                exit 0
                ;;
            /*)
                echo -e "${YELLOW}Unknown command. Type /help for help.${NC}"
                ;;
            *)
                chat "$input"
                ;;
        esac
    done
}

# Single query mode
single_query() {
    local prompt="$*"
    chat "$prompt"
}

# Main
main() {
    # Check if Ollama is available
    if ! command -v ollama &>/dev/null; then
        echo -e "${RED}Error: Ollama not installed${NC}"
        echo "Install with: curl -fsSL https://ollama.com/install.sh | sh"
        exit 1
    fi

    if [ $# -eq 0 ]; then
        # Interactive mode
        interactive
    else
        # Single query mode
        single_query "$@"
    fi
}

main "$@"

#!/bin/bash
# 🔒 CECE-SECRETS v1.0 - Encrypted Secrets Management
# Secure storage for API keys, passwords, and sensitive data

# BlackRoad Color Palette
BR_ORANGE=208
BR_PINK=198
BR_MAGENTA=163
BR_BLUE=33
BR_WHITE=255

fg() { echo -e "\033[38;5;${1}m"; }
RESET='\033[0m'
BOLD='\033[1m'

CECE_HOME="${CECE_HOME:-$HOME/cece}"
SECRETS_DIR="$CECE_HOME/secrets"
SECRETS_FILE="$SECRETS_DIR/vault.enc"
SECRETS_KEY_FILE="$SECRETS_DIR/.key"
SECRETS_PLAIN="$SECRETS_DIR/.vault.json"
SECRETS_LOG="$SECRETS_DIR/access.log"

mkdir -p "$SECRETS_DIR"
chmod 700 "$SECRETS_DIR"

banner() {
    echo -e "${BOLD}$(fg $BR_PINK)╔════════════════════════════════════════════════════════════╗${RESET}"
    echo -e "$(fg $BR_PINK)║${RESET}            ${BOLD}$(fg $BR_WHITE)🔒 CECE-SECRETS - Encrypted Vault${RESET}             $(fg $BR_PINK)║${RESET}"
    echo -e "$(fg $BR_PINK)╚════════════════════════════════════════════════════════════╝${RESET}"
}

log_access() {
    echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] $1" >> "$SECRETS_LOG"
}

# Generate or get encryption key
get_key() {
    if [ ! -f "$SECRETS_KEY_FILE" ]; then
        # Generate a new key
        openssl rand -base64 32 > "$SECRETS_KEY_FILE"
        chmod 600 "$SECRETS_KEY_FILE"
        echo -e "$(fg $BR_BLUE)✓${RESET} New encryption key generated"
    fi
    cat "$SECRETS_KEY_FILE"
}

# Encrypt the vault
encrypt_vault() {
    local key=$(get_key)
    if [ -f "$SECRETS_PLAIN" ]; then
        openssl enc -aes-256-cbc -salt -pbkdf2 -in "$SECRETS_PLAIN" -out "$SECRETS_FILE" -pass pass:"$key" 2>/dev/null
        rm -f "$SECRETS_PLAIN"
    fi
}

# Decrypt the vault
decrypt_vault() {
    local key=$(get_key)
    if [ -f "$SECRETS_FILE" ]; then
        openssl enc -aes-256-cbc -d -pbkdf2 -in "$SECRETS_FILE" -out "$SECRETS_PLAIN" -pass pass:"$key" 2>/dev/null
        return $?
    else
        echo '{}' > "$SECRETS_PLAIN"
    fi
}

# Read vault (decrypts, reads, re-encrypts)
read_vault() {
    decrypt_vault || echo '{}' > "$SECRETS_PLAIN"
    cat "$SECRETS_PLAIN"
}

# Write vault
write_vault() {
    local data="$1"
    echo "$data" > "$SECRETS_PLAIN"
    encrypt_vault
}

# Initialize vault
cmd_init() {
    banner
    echo ""

    if [ -f "$SECRETS_FILE" ]; then
        echo -e "$(fg $BR_PINK)Warning: Vault already exists!${RESET}"
        read -p "Reinitialize? This will DELETE all secrets! (yes/no) " confirm
        [ "$confirm" != "yes" ] && return
    fi

    # Generate new key
    rm -f "$SECRETS_KEY_FILE"
    get_key > /dev/null

    # Create empty vault
    echo '{}' > "$SECRETS_PLAIN"
    encrypt_vault

    echo -e "$(fg $BR_BLUE)✓${RESET} Vault initialized"
    echo -e "$(fg $BR_WHITE)Key stored in:${RESET} $SECRETS_KEY_FILE"
    echo ""
    echo -e "$(fg $BR_PINK)IMPORTANT: Back up your key file!${RESET}"

    log_access "INIT: Vault initialized"
}

# Set a secret
cmd_set() {
    local key="$1"
    local value="$2"

    if [ -z "$key" ]; then
        echo "Usage: cece-secrets set <key> [value]"
        echo "If value is omitted, you'll be prompted (hidden input)"
        return 1
    fi

    if [ -z "$value" ]; then
        echo -n "Enter value for '$key' (hidden): "
        read -rs value
        echo ""
    fi

    if [ -z "$value" ]; then
        echo -e "$(fg $BR_PINK)Error: Value cannot be empty${RESET}"
        return 1
    fi

    local vault=$(read_vault)
    vault=$(echo "$vault" | jq --arg k "$key" --arg v "$value" '.[$k] = $v')
    write_vault "$vault"

    echo -e "$(fg $BR_BLUE)✓${RESET} Secret stored: $(fg $BR_WHITE)$key${RESET}"
    log_access "SET: $key"
}

# Get a secret
cmd_get() {
    local key="$1"

    if [ -z "$key" ]; then
        echo "Usage: cece-secrets get <key>"
        return 1
    fi

    local vault=$(read_vault)
    local value=$(echo "$vault" | jq -r --arg k "$key" '.[$k] // empty')

    if [ -n "$value" ]; then
        echo "$value"
        log_access "GET: $key"
    else
        echo -e "$(fg $BR_PINK)Secret not found:${RESET} $key" >&2
        return 1
    fi
}

# Delete a secret
cmd_delete() {
    local key="$1"

    if [ -z "$key" ]; then
        echo "Usage: cece-secrets delete <key>"
        return 1
    fi

    local vault=$(read_vault)
    vault=$(echo "$vault" | jq --arg k "$key" 'del(.[$k])')
    write_vault "$vault"

    echo -e "$(fg $BR_BLUE)✓${RESET} Secret deleted: $(fg $BR_WHITE)$key${RESET}"
    log_access "DELETE: $key"
}

# List all secret keys (not values!)
cmd_list() {
    banner
    echo ""
    echo -e "$(fg $BR_WHITE)Stored Secrets:${RESET}"
    echo ""

    local vault=$(read_vault)
    local keys=$(echo "$vault" | jq -r 'keys[]' 2>/dev/null)

    if [ -z "$keys" ]; then
        echo "  No secrets stored."
        return
    fi

    echo "$keys" | while read -r key; do
        local value=$(echo "$vault" | jq -r --arg k "$key" '.[$k]')
        local masked="${value:0:3}***"
        echo -e "  $(fg $BR_WHITE)$key${RESET} = $(fg $BR_MAGENTA)$masked${RESET}"
    done

    echo ""
    local count=$(echo "$vault" | jq 'length')
    echo -e "  $(fg $BR_WHITE)Total: $count secrets${RESET}"

    log_access "LIST: viewed keys"
}

# Export secrets (encrypted)
cmd_export() {
    local output="${1:-$SECRETS_DIR/export-$(date +%Y%m%d).enc}"

    cp "$SECRETS_FILE" "$output"
    echo -e "$(fg $BR_BLUE)✓${RESET} Exported to: $(fg $BR_WHITE)$output${RESET}"
    echo -e "$(fg $BR_PINK)Remember: You need the key file to decrypt!${RESET}"

    log_access "EXPORT: to $output"
}

# Import secrets
cmd_import() {
    local input="$1"

    if [ -z "$input" ] || [ ! -f "$input" ]; then
        echo -e "$(fg $BR_PINK)Error: File not found${RESET}"
        return 1
    fi

    echo -e "$(fg $BR_PINK)Warning: This will MERGE with existing secrets${RESET}"
    read -p "Continue? (yes/no) " confirm
    [ "$confirm" != "yes" ] && return

    # Try to decrypt with current key
    local key=$(get_key)
    local imported=$(openssl enc -aes-256-cbc -d -pbkdf2 -in "$input" -pass pass:"$key" 2>/dev/null)

    if [ -z "$imported" ]; then
        echo -e "$(fg $BR_PINK)Error: Could not decrypt (wrong key?)${RESET}"
        return 1
    fi

    # Merge with existing
    local vault=$(read_vault)
    vault=$(echo "$vault $imported" | jq -s '.[0] * .[1]')
    write_vault "$vault"

    echo -e "$(fg $BR_BLUE)✓${RESET} Secrets imported and merged"
    log_access "IMPORT: from $input"
}

# Generate a random secret
cmd_generate() {
    local key="$1"
    local length="${2:-32}"

    if [ -z "$key" ]; then
        # Just generate and print
        openssl rand -base64 "$length" | tr -d '\n'
        echo ""
        return
    fi

    local value=$(openssl rand -base64 "$length" | tr -d '\n')
    cmd_set "$key" "$value"

    echo -e "$(fg $BR_WHITE)Generated value:${RESET} ${value:0:8}..."
}

# Show access log
cmd_log() {
    local count="${1:-20}"

    echo -e "$(fg $BR_WHITE)Recent Access Log:${RESET}"
    echo ""

    if [ -f "$SECRETS_LOG" ]; then
        tail -n "$count" "$SECRETS_LOG"
    else
        echo "No access log yet."
    fi
}

# Rotate encryption key
cmd_rotate() {
    echo -e "$(fg $BR_PINK)Warning: This will generate a new encryption key${RESET}"
    read -p "Continue? (yes/no) " confirm
    [ "$confirm" != "yes" ] && return

    # Decrypt with old key
    local vault=$(read_vault)

    # Generate new key
    rm -f "$SECRETS_KEY_FILE"
    get_key > /dev/null

    # Re-encrypt with new key
    write_vault "$vault"

    echo -e "$(fg $BR_BLUE)✓${RESET} Encryption key rotated"
    echo -e "$(fg $BR_PINK)IMPORTANT: Update your key backup!${RESET}"

    log_access "ROTATE: key rotated"
}

# Environment export
cmd_env() {
    local prefix="${1:-CECE_}"

    local vault=$(read_vault)
    echo "$vault" | jq -r 'to_entries[] | "export \(.key | ascii_upcase)=\(.value)"' | sed "s/export /export ${prefix}/"

    log_access "ENV: exported as env vars"
}

# Help
cmd_help() {
    banner
    echo ""
    echo -e "$(fg $BR_WHITE)Usage:${RESET} cece-secrets <command> [args]"
    echo ""
    echo -e "$(fg $BR_BLUE)Commands:${RESET}"
    echo "  init                    Initialize vault"
    echo "  set <key> [value]       Store a secret"
    echo "  get <key>               Retrieve a secret"
    echo "  delete <key>            Delete a secret"
    echo "  list                    List all keys"
    echo "  generate [key] [len]    Generate random secret"
    echo "  export [file]           Export encrypted vault"
    echo "  import <file>           Import and merge"
    echo "  rotate                  Rotate encryption key"
    echo "  env [prefix]            Export as env vars"
    echo "  log [n]                 Show access log"
    echo ""
    echo -e "$(fg $BR_WHITE)Examples:${RESET}"
    echo "  cece-secrets set OPENAI_KEY sk-xxxxx"
    echo "  cece-secrets get OPENAI_KEY"
    echo "  cece-secrets generate API_SECRET 64"
    echo "  eval \$(cece-secrets env)  # Load into shell"
    echo ""
    echo -e "$(fg $BR_PINK)Security:${RESET}"
    echo "  • Secrets encrypted with AES-256-CBC"
    echo "  • Key stored separately in $SECRETS_KEY_FILE"
    echo "  • Back up your key file!"
}

# Main
main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        init) cmd_init ;;
        set|put|add) cmd_set "$@" ;;
        get) cmd_get "$@" ;;
        delete|del|rm) cmd_delete "$@" ;;
        list|ls) cmd_list ;;
        generate|gen) cmd_generate "$@" ;;
        export) cmd_export "$@" ;;
        import) cmd_import "$@" ;;
        rotate) cmd_rotate ;;
        env) cmd_env "$@" ;;
        log) cmd_log "$@" ;;
        help|--help|-h) cmd_help ;;
        *) echo "Unknown command: $cmd"; cmd_help ;;
    esac
}

main "$@"

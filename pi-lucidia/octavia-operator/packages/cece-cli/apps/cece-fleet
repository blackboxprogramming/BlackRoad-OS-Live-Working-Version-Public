#!/bin/bash
# 🚀 CECE-FLEET v1.0 - Device Fleet Manager
# Manage and orchestrate all BlackRoad devices

PINK='\033[38;5;205m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
WHITE='\033[1;37m'
NC='\033[0m'

# Device fleet configuration
declare -A DEVICES=(
    ["cecilia"]="192.168.4.89:Pi5+Hailo8:Primary AI"
    ["lucidia"]="192.168.4.38:Pi4+Hailo8:AI Inference"
    ["alice"]="192.168.4.49:Pi4:Worker"
    ["aria"]="192.168.4.82:Pi5:Harmony"
    ["octavia"]="192.168.4.81:Pi5:Multi-arm"
)

declare -A TAILSCALE=(
    ["cecilia"]="100.72.180.98"
    ["lucidia"]="100.66.235.47"
    ["alice"]="100.77.210.18"
    ["aria"]="100.109.14.17"
    ["octavia"]="100.83.149.86"
)

banner() {
    echo -e "${PINK}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${PINK}║${NC}           ${WHITE}🚀 CECE-FLEET - Device Fleet Manager${NC}             ${PINK}║${NC}"
    echo -e "${PINK}╚════════════════════════════════════════════════════════════╝${NC}"
}

# Parse device info
get_ip() { echo "${DEVICES[$1]}" | cut -d: -f1; }
get_hw() { echo "${DEVICES[$1]}" | cut -d: -f2; }
get_role() { echo "${DEVICES[$1]}" | cut -d: -f3; }

# Check device status
check_device() {
    local name="$1"
    local ip=$(get_ip "$name")

    if ping -c 1 -W 2 "$ip" &>/dev/null; then
        return 0
    elif ping -c 1 -W 2 "${TAILSCALE[$name]}" &>/dev/null; then
        return 0
    fi
    return 1
}

# Get best IP for device
best_ip() {
    local name="$1"
    local ip=$(get_ip "$name")

    if ping -c 1 -W 1 "$ip" &>/dev/null; then
        echo "$ip"
    else
        echo "${TAILSCALE[$name]}"
    fi
}

# List all devices
cmd_list() {
    banner
    echo ""
    echo -e "${WHITE}Device Fleet Status:${NC}"
    echo ""

    printf "  ${CYAN}%-12s %-15s %-15s %-12s %s${NC}\n" "NAME" "IP" "HARDWARE" "STATUS" "ROLE"
    echo "  ─────────────────────────────────────────────────────────────────"

    for name in "${!DEVICES[@]}"; do
        local ip=$(get_ip "$name")
        local hw=$(get_hw "$name")
        local role=$(get_role "$name")

        if check_device "$name"; then
            local status="${GREEN}● online${NC}"
        else
            local status="${RED}○ offline${NC}"
        fi

        printf "  %-12s %-15s %-15s %-20b %s\n" "$name" "$ip" "$hw" "$status" "$role"
    done

    echo ""
    echo -e "  ${WHITE}Total:${NC} ${#DEVICES[@]} devices"
}

# SSH to a device
cmd_ssh() {
    local name="$1"
    shift

    if [ -z "$name" ]; then
        echo -e "${RED}Error:${NC} Please specify device name"
        echo "Usage: cece-fleet ssh <device> [command]"
        return 1
    fi

    if [ -z "${DEVICES[$name]}" ]; then
        echo -e "${RED}Error:${NC} Unknown device '$name'"
        return 1
    fi

    local ip=$(best_ip "$name")

    if [ $# -eq 0 ]; then
        # Interactive SSH
        echo -e "${CYAN}Connecting to $name ($ip)...${NC}"
        ssh "$name"
    else
        # Run command
        ssh "$name" "$@"
    fi
}

# Execute command on all devices
cmd_exec() {
    local cmd="$*"

    if [ -z "$cmd" ]; then
        echo -e "${RED}Error:${NC} Please specify command"
        echo "Usage: cece-fleet exec <command>"
        return 1
    fi

    banner
    echo ""
    echo -e "${CYAN}Executing on all devices:${NC} $cmd"
    echo ""

    for name in "${!DEVICES[@]}"; do
        echo -e "${WHITE}━━━ $name ━━━${NC}"

        if check_device "$name"; then
            ssh "$name" "bash --norc --noprofile -c '$cmd'" 2>/dev/null || echo -e "${RED}Command failed${NC}"
        else
            echo -e "${RED}Device offline${NC}"
        fi
        echo ""
    done
}

# Copy file to all devices
cmd_deploy() {
    local src="$1"
    local dst="$2"

    if [ -z "$src" ] || [ -z "$dst" ]; then
        echo "Usage: cece-fleet deploy <source> <destination>"
        return 1
    fi

    if [ ! -f "$src" ]; then
        echo -e "${RED}Error:${NC} Source file not found: $src"
        return 1
    fi

    banner
    echo ""
    echo -e "${CYAN}Deploying:${NC} $src → $dst"
    echo ""

    for name in "${!DEVICES[@]}"; do
        echo -n "  $name: "

        if check_device "$name"; then
            cat "$src" | ssh "$name" "bash --norc --noprofile -c 'mkdir -p \$(dirname $dst) && cat > $dst'" 2>/dev/null
            if [ $? -eq 0 ]; then
                echo -e "${GREEN}✓${NC}"
            else
                echo -e "${RED}✗${NC}"
            fi
        else
            echo -e "${YELLOW}offline${NC}"
        fi
    done
}

# Reboot a device
cmd_reboot() {
    local name="$1"

    if [ -z "$name" ]; then
        echo -e "${RED}Error:${NC} Please specify device name"
        return 1
    fi

    if [ "$name" = "all" ]; then
        echo -e "${YELLOW}Warning: This will reboot ALL devices!${NC}"
        read -p "Are you sure? (yes/no) " confirm
        [ "$confirm" != "yes" ] && return

        for n in "${!DEVICES[@]}"; do
            echo -n "  Rebooting $n... "
            ssh "$n" "sudo reboot" 2>/dev/null &
            echo -e "${GREEN}sent${NC}"
        done
    else
        echo -e "${CYAN}Rebooting $name...${NC}"
        ssh "$name" "sudo reboot" 2>/dev/null
    fi
}

# Get system info from all devices
cmd_info() {
    banner
    echo ""
    echo -e "${WHITE}Fleet System Information:${NC}"
    echo ""

    for name in "${!DEVICES[@]}"; do
        echo -e "${CYAN}━━━ $name ━━━${NC}"

        if check_device "$name"; then
            ssh "$name" "bash --norc --noprofile -c '
                echo \"  Uptime: \$(uptime -p)\"
                echo \"  Memory: \$(free -h | grep Mem | awk \"{print \\\$3\\\"/\\\"\\\$2}\")\"
                echo \"  Disk:   \$(df -h / | tail -1 | awk \"{print \\\$3\\\"/\\\"\\\$2}\")\"
                if [ -f /sys/class/thermal/thermal_zone0/temp ]; then
                    echo \"  Temp:   \$(($(cat /sys/class/thermal/thermal_zone0/temp) / 1000))°C\"
                fi
            '" 2>/dev/null || echo -e "${RED}  Could not get info${NC}"
        else
            echo -e "${RED}  Device offline${NC}"
        fi
        echo ""
    done
}

# Update all devices
cmd_update() {
    banner
    echo ""
    echo -e "${CYAN}Updating all devices...${NC}"
    echo ""

    for name in "${!DEVICES[@]}"; do
        echo -e "${WHITE}━━━ $name ━━━${NC}"

        if check_device "$name"; then
            ssh "$name" "bash --norc --noprofile -c 'sudo apt update && sudo apt upgrade -y'" 2>/dev/null
        else
            echo -e "${RED}Device offline${NC}"
        fi
        echo ""
    done
}

# Help
cmd_help() {
    banner
    echo ""
    echo -e "${WHITE}Usage:${NC} cece-fleet <command> [args]"
    echo ""
    echo -e "${CYAN}Commands:${NC}"
    echo "  list              List all devices and status"
    echo "  ssh <device>      SSH to a device"
    echo "  exec <cmd>        Execute command on all devices"
    echo "  deploy <src> <dst> Deploy file to all devices"
    echo "  info              Get system info from all devices"
    echo "  reboot <device>   Reboot device (or 'all')"
    echo "  update            Update all devices (apt upgrade)"
    echo ""
    echo -e "${WHITE}Devices:${NC}"
    for name in "${!DEVICES[@]}"; do
        echo "  • $name ($(get_role "$name"))"
    done
}

# Main
main() {
    local cmd="${1:-list}"
    shift 2>/dev/null || true

    case "$cmd" in
        list|ls) cmd_list ;;
        ssh) cmd_ssh "$@" ;;
        exec|run) cmd_exec "$@" ;;
        deploy|cp) cmd_deploy "$@" ;;
        info) cmd_info ;;
        reboot) cmd_reboot "$@" ;;
        update) cmd_update ;;
        help|--help|-h) cmd_help ;;
        *) echo "Unknown command: $cmd"; cmd_help ;;
    esac
}

main "$@"

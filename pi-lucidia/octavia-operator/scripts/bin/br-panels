#!/usr/bin/env bash
SESSION=blackroad
WINDOW=panels

tmux has-session -t $SESSION 2>/dev/null || tmux new -d -s $SESSION
tmux kill-window -t $SESSION:$WINDOW 2>/dev/null
tmux new-window -t $SESSION -n $WINDOW
tmux split-window -h
tmux split-window -v
tmux split-window -v
tmux split-window -v
tmux select-layout tiled
tmux select-window -t $SESSION:$WINDOW
